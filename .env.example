# App
APP_URL="http://localhost:3000"
JWT_SECRET="replace-with-a-long-random-secret"

# AI
GEMINI_API_KEY="your-gemini-api-key"

# Database
MONGODB_URI="mongodb+srv://user:password@example.mongodb.net/sentilytics"

# Email delivery
# Prefer Resend on hosts that block SMTP ports.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Sentilytics <onboarding@resend.dev>"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_TIMEOUT_MS="10000"

# Emergency login when email delivery is unavailable.
# Use a private email and a strong OTP/password-like value.
FALLBACK_LOGIN_EMAIL=""
FALLBACK_LOGIN_OTP=""

# Social Media API Keys
YOUTUBE_API_KEY=""
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""
REDDIT_USER_AGENT="SocialSentimentPro/1.0"
